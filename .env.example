# Copy to .env and fill in your own X cookie values (see the README for how to grab them).
# .env is gitignored — these never leave your machine.
X_AUTH_TOKEN=your_auth_token_cookie_here
X_CT0=your_ct0_cookie_here

# Optional: cap how many bookmarks get a (slower) detail fetch per run. Default 400.
# BM_ENRICH_LIMIT=400
